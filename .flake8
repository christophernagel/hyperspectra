[flake8]
max-line-length = 100
exclude =
    .git,
    __pycache__,
    build,
    dist,
    legacy_scripts,
    .eggs
# Ignore common non-critical warnings:
# E501 handled by max-line-length
# W503 line break before binary operator (conflicts with black)
# E203 whitespace before ':' (conflicts with black)
extend-ignore = W503, E203
per-file-ignores =
    __init__.py:F401
